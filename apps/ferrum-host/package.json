{
  "name": "ferrum-host",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas-build-pre-install": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y && . $HOME/.cargo/env && rustup target add aarch64-apple-ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "55.0.10-canary-20260328-bdc6273",
    "expo-build-properties": "55.0.11-canary-20260328-bdc6273",
    "expo-status-bar": "55.0.5-canary-20260328-bdc6273",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "@react-native-native/nativ-fabric": "workspace:*"
  },
  "private": true,
  "codegenConfig": {
    "name": "FerrumBenchSpec",
    "type": "modules",
    "jsSrcsDir": "src/specs",
    "ios": {
      "srcsDir": "ios"
    },
    "android": {
      "javaPackageName": "com.nativhost"
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
