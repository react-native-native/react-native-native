<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ferrum.app">

    <!--
        Minimal manifest for Project Ferrum Phase 0.

        No permissions beyond what the system requires for a foreground Activity.
        No services, no content providers, no broadcast receivers.

        Phase 1 will add:
          - android.permission.INTERNET (if loading bundles from Metro dev server)
          - android:configChanges on MainActivity for orientation/keyboard

        Phase 3 will add:
          - android.permission.CAMERA (ferrum-camera module)
    -->

    <application
        android:label="Ferrum"
        android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:hardwareAccelerated="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait">
            <!--
                screenOrientation="portrait" avoids Activity recreation on rotation
                for Phase 0. Phase 1 will handle configuration changes properly.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
