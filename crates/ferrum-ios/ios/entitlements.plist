<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Minimal entitlements for Phase 0 development builds.
  Only get-task-allow is needed for ad-hoc/dev signing with codesign CLI.
  application-identifier and team-identifier are injected automatically
  by the provisioning profile at sign time.
-->
<plist version="1.0">
<dict>
    <!-- Allow debugging via LLDB over USB (development only) -->
    <key>get-task-allow</key>
    <true/>
</dict>
</plist>
