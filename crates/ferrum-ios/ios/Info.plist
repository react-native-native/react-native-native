<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Application identity -->
    <key>CFBundleIdentifier</key>
    <string>com.ferrum.app</string>

    <key>CFBundleName</key>
    <string>Ferrum</string>

    <key>CFBundleDisplayName</key>
    <string>Ferrum</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>

    <key>CFBundleExecutable</key>
    <string>Ferrum</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <!-- iOS deployment target (Phase 0: physical device, iOS 16+) -->
    <key>MinimumOSVersion</key>
    <string>16.0</string>

    <!-- Supported device families: 1 = iPhone, 2 = iPad -->
    <key>UIDeviceFamilyCompatible</key>
    <array>
        <integer>1</integer>
        <integer>2</integer>
    </array>

    <!-- Required device capabilities for App Store / device targeting -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>

    <!-- Supported interface orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Launch screen — required on device even if empty -->
    <key>UILaunchStoryboardName</key>
    <string></string>

    <!-- Scene manifest — required on iOS 13+. Empty UISceneConfigurations
         causes UIKit to fall back to UIApplicationDelegate window management,
         which is what our Rust AppDelegate implements. -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
</dict>
</plist>
